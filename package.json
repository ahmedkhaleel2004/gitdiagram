{
  "name": "gitdiagram",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run --bun next build",
    "check": "bun run lint && bun run typecheck",
    "dev": "./scripts/dev-turbo.sh",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "preview": "next build && next start",
    "start": "next start",
    "quota:today": "bun scripts/complimentary-quota-today.mjs",
    "browse:migrate-index": "bun scripts/migrate-browse-index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "perf:budget": "node scripts/check-performance-budgets.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1086.0",
    "@mermaid-js/layout-elk": "^0.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tooltip": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "geist": "^1.7.2",
    "lucide-react": "^1.24.0",
    "mermaid": "^11.16.0",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "openai": "^6.46.0",
    "posthog-js": "^1.399.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "overrides": {
    "dompurify": "3.4.12",
    "lodash-es": "^4.18.1",
    "postcss": "^8.5.19",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jsdom": "28.0.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.10",
    "jsdom": "29.1.1",
    "postcss": "^8.5.19",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "vitest": "4.1.10"
  },
  "engines": {
    "bun": ">=1.3.11 <2"
  },
  "packageManager": "bun@1.3.11"
}
