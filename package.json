{
  "name": "gitdiagram",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --bun next build",
    "check": "bun run lint && bun run typecheck",
    "dev": "./scripts/dev-turbo.sh",
    "install:backend": "cd backend && bun install --frozen-lockfile && uv sync --no-install-project",
    "dev:backend": "cd backend && ENVIRONMENT=development uv run --no-dev uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "preview": "bun --bun next build && bun --bun next start",
    "start": "bun --bun next start",
    "start:backend": "cd backend && ENVIRONMENT=production uv run --no-dev uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "quota:today": "bun scripts/complimentary-quota-today.mjs",
    "test": "vitest run",
    "test:backend": "cd backend && uv run pytest -q",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format:write": "prettier --write \"**/*.{ts,tsx,js,jsx,mdx}\" --cache",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mdx}\" --cache"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@mermaid-js/layout-elk": "^0.2.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "geist": "^1.7.0",
    "jsdom": "29.0.1",
    "linkedom": "^0.18.12",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.14.0",
    "next": "^16.2.1",
    "next-themes": "^0.4.6",
    "openai": "^6.33.0",
    "posthog-js": "^1.364.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "svg-pan-zoom": "^3.6.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "4.1.2"
  },
  "ct3aMetadata": {
    "initVersion": "7.38.1"
  },
  "engines": {
    "bun": ">=1.3.11 <2"
  },
  "packageManager": "bun@1.3.11"
}
